# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Neon Postgres ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── Upwork API (OAuth 2.0) ───────────────────────────────────────────────────
# Register your app at: https://developers.upwork.com
# Then run: npx tsx src/setup-oauth.ts  to get your refresh token
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret
UPWORK_REFRESH_TOKEN=your_upwork_refresh_token

# ── Upwork Search Queries (comma-separated, add as many as you want) ──────────
UPWORK_SEARCH_QUERIES=voice ai agent,voice ai architect,conversational ai voice,realtime voice agent,ai phone agent,voice bot twilio,deepgram elevenlabs,livekit voice,vapi retell ai,ai calling agent

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often to poll Upwork in minutes (default: 30)
POLL_INTERVAL_MINUTES=30

# ── Your Profile (used for proposal drafting when you press the button) ────────
FREELANCER_NAME=Your Name
FREELANCER_SKILLS=Voice AI, Conversational AI, LiveKit, Deepgram, ElevenLabs, OpenAI Realtime API, Vapi, Twilio, WebRTC, real-time speech pipelines
FREELANCER_EXPERIENCE_YEARS=5
FREELANCER_BIO=I build and fix real-time voice AI systems — from greenfield voice agents to debugging broken ElevenLabs/Deepgram pipelines. My work spans sales automation, healthcare, and customer support.
